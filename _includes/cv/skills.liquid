{% comment %}
  Unified skills entry renderer for both formats
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="skill-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }}"></i>
      {% endif %}
      {% capture skill_label %}
        {% if entry.label %}{{ entry.label }}{% else %}{{ entry.name }}{% endif %}
      {% endcapture %}
      <strong>
        {{- skill_label -}}
        {%- if entry.level %} ({{ entry.level }}){% endif %}:</strong
      >
      {% if entry.details %}
        {{ entry.details }}
      {% elsif entry.keywords %}
        {% for keyword in entry.keywords %}
          {% if forloop.last %}
            {{ keyword }}
          {% else %}
            {{ keyword }},
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .skill-item {
    padding: 0.5rem 0;
  }
</style>
